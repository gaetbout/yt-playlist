{
  "manifest_version": 3,
  "name": "YouTube Playlist Helper",
  "version": "1.0",
  "description": "Adds quick buttons to YouTube thumbnails for managing playlists (Watch Later, Music, etc.)",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "helpers.js",
        "menu-phrases.js",
        "thumbnail-buttons.js",
        "playlist-management.js",
        "page-monitor.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}
